# IPython
profile_default/
ipython_config.py

# pyenv
#   For a library or app, you might want to share your .python-version.
#   For an executable, it's common to ignore this.
#.python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if you choose to not to share the lock file:
#Pipfile.lock

# poetry
#   Similar to Pipenv, poetry.lock is generally recommended to be committed.
#poetry.lock

# pdm
#   Similar to Pipenv and Poetry, pdm.lock is generally recommended to be committed
.pdm-plugins/
.pdm-build/

# PEP 582; project packages directory (e.g. pdm)
__pypackages__/

# Celery stuff
celerybeat-schedule
celerybeat.pid

# SageMath parsed files
*.sage.py

